{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aratu.dev/schemas/engine/v1/error-envelope.schema.json",
  "title": "ErrorEnvelope",
  "description": "Stable engine error envelope. It must not contain credentials, authorization data, stack traces, raw driver secrets, or sensitive values.",
  "type": "object",
  "additionalProperties": false,
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable", "requestId", "details"],
      "properties": {
        "code": {
          "type": "string",
          "description": "Stable machine-readable error code.",
          "minLength": 3,
          "maxLength": 64,
          "pattern": "^[A-Z][A-Z0-9_]+$"
        },
        "message": {
          "type": "string",
          "description": "Bounded user-facing message with no sensitive implementation details.",
          "minLength": 1,
          "maxLength": 500
        },
        "retryable": {
          "type": "boolean"
        },
        "requestId": {
          "type": "string",
          "minLength": 8,
          "maxLength": 128,
          "pattern": "^[A-Za-z0-9_-]+$"
        },
        "details": {
          "type": "object",
          "description": "Bounded, code-specific, non-sensitive details.",
          "maxProperties": 16,
          "additionalProperties": true
        }
      }
    }
  }
}
