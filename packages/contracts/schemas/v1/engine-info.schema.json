{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aratu.dev/schemas/engine/v1/engine-info.schema.json",
  "title": "EngineInfo",
  "description": "Build and runtime identity returned by the authenticated engine information endpoint.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "engineVersion", "protocolVersion", "target"],
  "properties": {
    "name": {
      "const": "aratu-engine"
    },
    "engineVersion": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$"
    },
    "protocolVersion": {
      "type": "string",
      "pattern": "^[1-9][0-9]*$"
    },
    "sourceRevision": {
      "type": "string",
      "description": "Source-control revision embedded at build time when available.",
      "minLength": 7,
      "maxLength": 64,
      "pattern": "^[0-9A-Fa-f]+$"
    },
    "buildTime": {
      "type": "string",
      "description": "RFC 3339 build timestamp when reproducibly supplied by the build pipeline.",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["os", "arch"],
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[a-z0-9_]+$"
        },
        "arch": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[a-z0-9_]+$"
        }
      }
    }
  }
}
